  </div>
</Layout>

<script>
  const navTooltip = document.createElement("div");
  navTooltip.className = "nav-tooltip";
  navTooltip.style.display = "none";
  document.body.appendChild(navTooltip);

  document.querySelectorAll(".nav-link[data-nav-tip]").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const tip = (link as HTMLElement).dataset.navTip;
      if (!tip) return;
      navTooltip.textContent = tip;
      navTooltip.style.display = "block";
      const rect = (link as HTMLElement).getBoundingClientRect();
      const pad = 4;
      let x = rect.left;
      const y = rect.bottom + pad;
      const tw = navTooltip.offsetWidth;
      if (x + tw > window.innerWidth - pad) x = window.innerWidth - tw - pad;
      navTooltip.style.left = x + "px";
      navTooltip.style.top = y + "px";
    });
    link.addEventListener("mouseleave", () => {
      navTooltip.style.display = "none";
    });
  });
</script>

<style is:global>
  /* ===== Top Navigation ===== */
  .top-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #ccc;
    background: white;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-name {
    font-weight: 700;
    border: 1px solid #333;
    padding: 0.15rem 0.5rem;
    color: var(--color-black);
    text-decoration: none;
  }

  .site-name:hover {
    border-color: black;
  }

  .nav-link {
    color: var(--color-black);
    text-decoration: none;
  }

  .nav-link.active {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .nav-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ===== Page body ===== */
  html, body {
    background: white !important;
    color: var(--color-black);
  }

  .results-body {
    max-width: 680px;
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-black);
  }

  .results-body p {
    margin-bottom: 1.5rem;
  }

  /* ===== Nav Tooltip ===== */
  .nav-tooltip {
    position: fixed;
    z-index: 200;
    max-width: 300px;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.5;
    pointer-events: none;
    border: 1px solid #ccc;
    background: var(--color-grey);
    color: var(--color-black);
  }
</style>
