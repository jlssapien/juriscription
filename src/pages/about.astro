---
import Layout from "../layouts/Layout.astro";
import AboutContent from "../content/about.md";
---

<Layout title="About">
  <nav class="top-nav">
    <div class="nav-left">
      <a href="/" class="site-name">JURISCRIPTION</a>
      <a href="/" class="nav-link">MAIN DATASET</a>
      <a href="/fda-to-mhra" class="nav-link" data-nav-tip="This sheet matches each drug in the FDA dataset to the closest drug (based on ingredients and dosage) in the MHRA dataset.">FDA → MHRA</a>
      <a href="/mhra-to-fda" class="nav-link" data-nav-tip="This sheet matches each drug in the MHRA dataset to the closest drug (based on ingredients and dosage) in the FDA dataset.">MHRA → FDA</a>
      <span class="nav-sep">|</span>
      <a href="/results" class="nav-link">RESULTS</a>
      <a href="/methods" class="nav-link">METHODOLOGY</a>
      <a href="/regulatory-map" class="nav-link">MAP</a>
      <a href="/about" class="nav-link active">ABOUT</a>
    </div>
  </nav>

  <div class="about-body">
    <AboutContent />
  </div>
</Layout>

<script>
  const navTooltip = document.createElement("div");
  navTooltip.className = "nav-tooltip";
  navTooltip.style.display = "none";
  document.body.appendChild(navTooltip);

  document.querySelectorAll(".nav-link[data-nav-tip]").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const tip = (link as HTMLElement).dataset.navTip;
      if (!tip) return;
      navTooltip.textContent = tip;
      navTooltip.style.display = "block";
      const rect = (link as HTMLElement).getBoundingClientRect();
      const pad = 4;
      let x = rect.left;
      const y = rect.bottom + pad;
      const tw = navTooltip.offsetWidth;
      if (x + tw > window.innerWidth - pad) x = window.innerWidth - tw - pad;
      navTooltip.style.left = x + "px";
      navTooltip.style.top = y + "px";
    });
    link.addEventListener("mouseleave", () => {
      navTooltip.style.display = "none";
    });
  });
</script>

<style is:global>
  /* ===== Top Navigation ===== */
  .top-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #ccc;
    background: white;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-name {
    font-weight: 700;
    border: 1px solid #333;
    padding: 0.15rem 0.5rem;
    color: var(--color-black);
    text-decoration: none;
  }

  .site-name:hover {
    border-color: black;
  }

  .nav-link {
    color: var(--color-black);
    text-decoration: none;
  }

  .nav-link.active {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .nav-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ===== Page body ===== */
  html, body {
    background: white !important;
    color: var(--color-black);
  }

  .about-body {
    max-width: 780px;
    margin: 0 auto;
    padding: 6rem 2rem 6rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-black);
  }

  /* ===== Prose styles for markdown content ===== */
  .about-body h1 {
    font-family: var(--font-mono);
    font-size: 1.0rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .about-body h2 {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 700;
    margin: 2.5rem 0 0.75rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-accent);
  }

  .about-body h2:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .about-body p {
    margin-bottom: 1rem;
  }

  .about-body ul,
  .about-body ol {
    margin: 0.75rem 0 1rem 1.5rem;
    padding: 0;
  }

  .about-body li {
    margin-bottom: 0.3rem;
  }

  .about-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .about-body a:hover {
    background: var(--color-accent-light);
  }

  .about-body strong {
    font-weight: 700;
  }

  .about-body em {
    font-style: italic;
  }

  /* ===== Nav Tooltip ===== */
  .nav-tooltip {
    position: fixed;
    z-index: 200;
    max-width: 300px;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.5;
    pointer-events: none;
    border: 1px solid #ccc;
    background: white;
    color: var(--color-black);
  }
</style>
