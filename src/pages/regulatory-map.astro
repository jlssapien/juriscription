  TD:"148", TG:"768", TT:"780", VC:"670"
};

// ── State ──────────────────────────────────────────────────────────

let agreements = [];
let entities = {};
let worldData = null;
let svg, g, projection, path;
let countryPaths;
let arcGroup, fillGroup;
let yearMin, yearMax;
let _currentZoomK = 1;
// Arcs drawn as Bézier curves in projected screen space (no geographic interpolation)
const _graticule = d3.geoGraticule();
const _mapBounds = {
  type: "Polygon",
  coordinates: [[
    [-180, -55],
    [ 180, -55],
    [ 180,  85],
    [-180,  85],
    [-180, -55]
  ]]
};
function currentZoomK() { return _currentZoomK; }
let _zoomBehavior = null;

// Active filters
const filters = {
  country: "all",
  categories: new Set(Object.keys(CATEGORY_COLORS)),
  yearRange: [1900, 2030],
  statuses: new Set(["active"])
};

// ── Init ───────────────────────────────────────────────────────────

async function init() {
  try {
    // Load world geometry: try local first, then CDN fallback
    async function loadWorld() {
      try {
        const local = await d3.json("/data/world-110m.json");
        if (local) return local;
      } catch (e) { /* local failed, try CDN */ }
      return d3.json("https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json");
    }

    worldData = await loadWorld();
    if (!worldData) {
      document.getElementById("loading").textContent = "Error loading world map data.";
      return;
    }

    // Use inlined agreement data
    agreements = AGREEMENTS_DATA.agreements;
    entities = AGREEMENTS_DATA.entities || {};
    window._countryCoordinates = AGREEMENTS_DATA.country_coordinates || {};

    document.getElementById("loading").style.display = "none";
    buildMap();
    buildFilters();
    buildLegend();
    render();
    setupInteractions();

    window.addEventListener("resize", debounce(() => { resizeMap(); render(); }, 200));

  } catch (err) {
    document.getElementById("loading").textContent = "Error: " + err.message;
    console.error(err);
  }
}

// ── Map Construction ───────────────────────────────────────────────

function buildMap() {
  const container = document.getElementById("map-container");
  const width = container.clientWidth;
  const height = container.clientHeight || window.innerHeight - 40;

  svg = d3.select("#map-container")
    .append("svg")
    .attr("width", width)
    .attr("height", height);

  // Arrow marker definitions — small chevrons proportionate to 0.4px stroke
  // markerUnits="strokeWidth" means marker dimensions scale with stroke-width,
  // which is already zoom-compensated (0.4/k), so markers auto-scale with zoom.
  const defs = svg.append("defs");
  Object.entries(CATEGORY_COLORS).forEach(([cat, color]) => {
    // marker-end arrow (at the tip of unilateral arcs)
    defs.append("marker")
      .attr("id", `arrow-${cat}`)
      .attr("viewBox", "0 0 4 3")
      .attr("refX", 4)
      .attr("refY", 1.5)
      .attr("markerWidth", 4)
      .attr("markerHeight", 3)
      .attr("markerUnits", "strokeWidth")
      .attr("orient", "auto")
      .append("path")
      .attr("d", "M0,0 L4,1.5 L0,3 Z")
      .style("fill", color);

    // marker-mid arrow (repeated along the arc)
    defs.append("marker")
      .attr("id", `arrow-mid-${cat}`)
      .attr("viewBox", "0 0 4 3")
      .attr("refX", 2)
      .attr("refY", 1.5)
      .attr("markerWidth", 4)
      .attr("markerHeight", 3)
      .attr("markerUnits", "strokeWidth")
      .attr("orient", "auto")
      .append("path")
      .attr("d", "M0,0 L4,1.5 L0,3 Z")
      .style("fill", color);
  });

  projection = d3.geoMercator()
    .fitSize([width, height], _mapBounds);

  path = d3.geoPath(projection);

  g = svg.append("g");

  // Sphere (ocean)
  g.append("path")
    .datum({ type: "Sphere" })
    .attr("class", "sphere")
    .attr("d", path);

  // Graticule
  g.append("path")
    .datum(_graticule())
    .attr("class", "graticule")
    .attr("d", path);

  // Country fill layer (for multilateral highlights)
  fillGroup = g.append("g").attr("class", "fill-layer");

  // Countries
  const countries = topojson.feature(worldData, worldData.objects.countries);
  countryPaths = g.append("g").attr("class", "countries-layer")
    .selectAll("path")
    .data(countries.features)
    .join("path")
    .attr("class", "country")
    .attr("d", path)
    .attr("data-id", d => d.id);

  // Arc layer
  arcGroup = g.append("g").attr("class", "arc-layer");

  // Zoom behavior
  const zoom = d3.zoom()
    .scaleExtent([1, 12])
    .on("zoom", (event) => {
      g.attr("transform", event.transform);
      _currentZoomK = event.transform.k;
      // Scale strokes inversely to keep consistent visual weight
      g.selectAll(".arc").attr("stroke-width", 0.4 / event.transform.k);
      g.selectAll(".country").attr("stroke-width", 0.25 / event.transform.k);
    });

  _zoomBehavior = zoom;
  svg.call(zoom);

  // Start zoomed in
  var k0 = 2.8;
  var t0 = d3.zoomIdentity
    .translate(width / 2, height / 2)
    .scale(k0)
    .translate(-width / 2, -height / 2);
  svg.call(zoom.transform, t0);
}

function resizeMap() {
  const container = document.getElementById("map-container");
  const width = container.clientWidth;
  const height = container.clientHeight || window.innerHeight - 40;
  svg.attr("width", width).attr("height", height);
  projection.fitSize([width, height], _mapBounds);
  path = d3.geoPath(projection);

  g.select(".sphere").attr("d", path);
  g.select(".graticule").attr("d", path(_graticule()));
  g.selectAll(".country").attr("d", path);
}

// ── Filters ────────────────────────────────────────────────────────

function buildFilters() {
  // Country dropdown
  const countrySet = new Set();
  agreements.forEach(a => {
    getAllParties(a).forEach(p => {
      if (p === "EU" && entities.EU) {
        entities.EU.fill_countries.forEach(c => countrySet.add(c));
      } else if (p !== "WHO") {
        countrySet.add(p);
      }
    });
  });

  const countrySelect = document.getElementById("country-filter");
  const sortedCountries = [...countrySet].sort((a, b) =>
    (COUNTRY_NAMES[a] || a).localeCompare(COUNTRY_NAMES[b] || b)
  );
  sortedCountries.forEach(code => {
    const opt = document.createElement("option");
    opt.value = code;
    opt.textContent = COUNTRY_NAMES[code] || code;
    countrySelect.appendChild(opt);
  });
  // Also add EU as a selectable entity
  if (entities.EU) {
    const opt = document.createElement("option");
    opt.value = "EU";
    opt.textContent = "European Union";
    countrySelect.appendChild(opt);
  }

  countrySelect.addEventListener("change", () => {
    filters.country = countrySelect.value;
    render();
    if (countrySelect.value !== "all") {
      showCountryPanel(countrySelect.value);
    } else {
      document.getElementById("info-panel").style.display = "none";
    }
  });

  // Category checkboxes
  const catContainer = document.getElementById("category-filters");
  Object.entries(CATEGORY_COLORS).forEach(([cat, color]) => {
    const label = document.createElement("label");
    const cb = document.createElement("input");
    cb.type = "checkbox";
    cb.checked = true;
    cb.value = cat;
    cb.addEventListener("change", () => {
      if (cb.checked) filters.categories.add(cat);
      else filters.categories.delete(cat);
      render();
    });
    const swatch = document.createElement("span");
    swatch.className = "color-swatch";
    swatch.style.background = color;
    label.appendChild(cb);
    label.appendChild(swatch);
    label.appendChild(document.createTextNode(" " + (CATEGORY_LABELS[cat] || cat)));
    catContainer.appendChild(label);
  });

  // Year range
  computeYearBounds();
  const yearMinEl = document.getElementById("year-min");
  const yearMaxEl = document.getElementById("year-max");
  yearMinEl.min = yearMin;
  yearMinEl.max = yearMax;
  yearMinEl.value = yearMin;
  yearMaxEl.min = yearMin;
  yearMaxEl.max = yearMax;
  yearMaxEl.value = yearMax;
  filters.yearRange = [yearMin, yearMax];
  updateYearLabel();

  yearMinEl.addEventListener("input", () => {
    if (+yearMinEl.value > +yearMaxEl.value) yearMinEl.value = yearMaxEl.value;
    filters.yearRange[0] = +yearMinEl.value;
    updateYearLabel();
    render();
  });
  yearMaxEl.addEventListener("input", () => {
    if (+yearMaxEl.value < +yearMinEl.value) yearMaxEl.value = yearMinEl.value;
    filters.yearRange[1] = +yearMaxEl.value;
    updateYearLabel();
    render();
  });

  // Status checkboxes
  const statusContainer = document.getElementById("status-filters");
  const statusLabels = { active: "Active", expired: "Expired", negotiation: "Under Negotiation" };
  Object.entries(statusLabels).forEach(([key, label]) => {
    const lbl = document.createElement("label");
    const cb = document.createElement("input");
    cb.type = "checkbox";
    cb.checked = STATUS_DEFAULTS[key];
    cb.value = key;
    if (STATUS_DEFAULTS[key]) filters.statuses.add(key);
    cb.addEventListener("change", () => {
      if (cb.checked) filters.statuses.add(key);
      else filters.statuses.delete(key);
      render();
    });
    lbl.appendChild(cb);
    lbl.appendChild(document.createTextNode(" " + label));
    statusContainer.appendChild(lbl);
  });
}

function computeYearBounds() {
  const years = agreements.map(a => a.year_signed || a.year_operational).filter(Boolean);
  yearMin = years.length ? Math.min(...years) : 1990;
  yearMax = years.length ? Math.max(...years) : 2025;
}

function updateYearLabel() {
  const label = document.getElementById("year-label");
  label.textContent = `${filters.yearRange[0]} – ${filters.yearRange[1]}`;
  // Update track highlight
  const track = document.getElementById("year-track-active");
  const range = yearMax - yearMin || 1;
  const left = ((filters.yearRange[0] - yearMin) / range) * 100;
  const right = ((filters.yearRange[1] - yearMin) / range) * 100;
  track.style.left = left + "%";
  track.style.width = (right - left) + "%";
}

function buildLegend() {
  const legend = document.getElementById("legend");
  let html = "";
  Object.entries(CATEGORY_COLORS).forEach(([cat, color]) => {
    html += `<div class="legend-item">
      <span class="legend-line" style="background:${color};"></span>
      <span>${CATEGORY_LABELS[cat] || cat}</span>
    </div>`;
  });
  html += `<div class="legend-item" style="margin-top:6px;border-top:1px solid #eee;padding-top:4px;">
    <span class="legend-line" style="background:#666;border-top:2px dashed #666;height:0;"></span>
    <span>Expired / Negotiation</span>
  </div>`;
  html += `<div class="legend-item">
    <span style="font-size:13px;letter-spacing:-1px;">&#9655;&#9655;&#9655;</span>
    <span>A relies on assessment of B</span>
  </div>`;
  legend.innerHTML = html;
}

// ── Rendering ──────────────────────────────────────────────────────

function getAllParties(a) {
  // Normalize: combine parties, from, and to into a single list
  const result = new Set(a.parties || []);
  if (a.from) result.add(a.from);
  if (a.to) a.to.forEach(t => result.add(t));
  return [...result];
}

function passesFilters(a) {
  // Category filter
  if (!filters.categories.has(a.category)) return false;

  // Status filter
  if (!filters.statuses.has(a.status)) return false;

  // Year filter
  const y = a.year_signed || a.year_operational;
  if (y && (y < filters.yearRange[0] || y > filters.yearRange[1])) return false;

  // Country filter
  if (filters.country !== "all") {
    const code = filters.country;
    const allParties = getAllParties(a);
    let match = allParties.includes(code);
    // If filtering by an EU member, also match agreements where EU is a party
    if (!match && entities.EU && entities.EU.fill_countries.includes(code)) {
      match = allParties.includes("EU");
    }
    // If filtering by EU, match agreements where EU is a party
    if (!match && code === "EU") {
      match = allParties.includes("EU");
    }
    if (!match) return false;
  }

  return true;
}

function getArcCoords(partyCode, agreement) {
  if (partyCode === "EU" && entities.EU) {
    // Use EMA location for EMA-specific agreements, Brussels for EU-level
    const isEma = agreement && (agreement.name || "").toLowerCase().includes("ema");
    return isEma ? (entities.EU.arc_location_ema || entities.EU.arc_location) : entities.EU.arc_location;
  }
  // Prefer data's country_coordinates over hardcoded centroids
  const dataCoords = window._countryCoordinates && window._countryCoordinates[partyCode];
  if (dataCoords) return dataCoords;
  const c = COUNTRY_CENTROIDS[partyCode];
  return c || null;
}

function render() {
  const visible = agreements.filter(passesFilters);

  // Clear previous
  arcGroup.selectAll("*").remove();
  fillGroup.selectAll("*").remove();

  // Reset all country fills
  countryPaths.style("fill", null).style("fill-opacity", null).attr("class", "country");

  // Track country agreement counts for hover info
  const countryAgreementCounts = {};
  visible.forEach(a => {
    const allP = getAllParties(a);
    allP.forEach(p => {
      if (p === "EU" && entities.EU) {
        entities.EU.fill_countries.forEach(c => {
          countryAgreementCounts[c] = (countryAgreementCounts[c] || 0) + 1;
        });
      } else {
        countryAgreementCounts[p] = (countryAgreementCounts[p] || 0) + 1;
      }
    });
  });

  // Country fills for multilateral agreements — category-colored, adaptive opacity
  // fillColors maps numId → { color, priority }
  const fillColors = {};
  visible.forEach(a => {
    if (a.type === "multilateral") {
      const color = CATEGORY_COLORS[a.category];
      const priority = CATEGORY_PRIORITY[a.category] || 0;
      const allP = getAllParties(a);
      allP.forEach(p => {
        const codes = (p === "EU" && entities.EU) ? entities.EU.fill_countries : [p];
        codes.forEach(c => {
          const numId = ISO2_TO_NUM[c];
          if (!numId) return;
          const key = String(numId);
          if (!fillColors[key] || priority > fillColors[key].priority) {
            fillColors[key] = { color, priority };
          }
        });
      });
    }
  });

  // Adaptive opacity: subtle when broad filters, bold when narrowed
  const activeCategories = filters.categories.size;
  const hasCountryFilter = filters.country !== "all";
  const fillOpacity = (hasCountryFilter || activeCategories <= 2) ? 0.5 : 0.15;

  // Apply country fills — must use .style() not .attr() (CSS specificity)
  countryPaths.each(function(d) {
    const entry = fillColors[String(d.id)];
    if (entry) {
      d3.select(this).style("fill", entry.color).style("fill-opacity", fillOpacity);
    } else {
      d3.select(this).style("fill", "#e0e0e0").style("fill-opacity", 1);
    }
  });

  // Store counts on country elements for hover
  countryPaths.each(function(d) {
    // Find ISO-2 from numeric (compare as strings to handle type mismatch)
    const iso2 = Object.entries(ISO2_TO_NUM).find(([, num]) => String(num) === String(d.id));
    if (iso2) {
      d3.select(this).attr("data-iso2", iso2[0])
        .attr("data-count", countryAgreementCounts[iso2[0]] || 0);
    }
  });

  // Draw arcs
  visible.forEach(a => {
    // Agreements with from/to fields always get arcs (unilateral reliance pathways)
    if (a.from && a.to && a.to.length > 0) {
      const fromCoords = getArcCoords(a.from, a);
      if (!fromCoords) return;
      a.to.forEach(toCode => {
        const toCoords = getArcCoords(toCode, a);
        if (!toCoords) return;
        if (a.flowReversed) {
          drawArc(toCoords, fromCoords, a, toCode, a.from);
        } else {
          drawArc(fromCoords, toCoords, a, a.from, toCode);
        }
        if (toCode === "EU" && entities.EU) {
          highlightEuFill(CATEGORY_COLORS[a.category]);
        }
        if (a.from === "EU" && entities.EU) {
          highlightEuFill(CATEGORY_COLORS[a.category]);
        }
      });
      return;
    }

    // True multilateral agreements (no from/to): country fills only, no arcs
    if (a.type === "multilateral") return;

    // Bilateral agreements with parties array
    const parties = a.parties || [];
    if (parties.length < 2) return;

    for (let i = 0; i < parties.length; i++) {
      for (let j = i + 1; j < parties.length; j++) {
        const from = getArcCoords(parties[i], a);
        const to = getArcCoords(parties[j], a);
        if (!from || !to) continue;
        drawArc(from, to, a, parties[i], parties[j]);
        if ((parties[i] === "EU" || parties[j] === "EU") && entities.EU) {
          highlightEuFill(CATEGORY_COLORS[a.category]);
        }
      }
    }
  });
}

function highlightEuFill(color) {
  if (!entities.EU) return;
  const hasCountryFilter = filters.country !== "all";
  const activeCategories = filters.categories.size;
  const opacity = (hasCountryFilter || activeCategories <= 2) ? 0.5 : 0.15;
  entities.EU.fill_countries.forEach(c => {
    const numId = ISO2_TO_NUM[c];
    if (numId) {
      countryPaths.filter(d => String(d.id) === String(numId))
        .style("fill", color).style("fill-opacity", opacity);
    }
  });
}

function drawArc(fromLatLon, toLatLon, agreement, fromCode, toCode) {
  const color = CATEGORY_COLORS[agreement.category] || "#999";
  const isDashed = agreement.status === "expired" || agreement.status === "negotiation";
  const isUnilateral = agreement.directionality === "unilateral";

  // Project geographic coordinates to screen pixels.
  // Drawing arcs in screen space (Bézier curves between pixel positions)
  // avoids the Mercator distortion problem where great-circle paths between
  // near-antipodal points (e.g. Singapore–US, 179° apart) traverse high
  // latitudes that Mercator stretches enormously, producing Arctic spikes.
  const p0 = projection([fromLatLon[1], fromLatLon[0]]);
  const p1 = projection([toLatLon[1], toLatLon[0]]);
  if (!p0 || !p1) return;

  // Compute a control point for a quadratic Bézier, offset perpendicular
  // to the line between endpoints. The offset creates the arc curvature.
  const mx = (p0[0] + p1[0]) / 2;
  const my = (p0[1] + p1[1]) / 2;
  const dx = p1[0] - p0[0];
  const dy = p1[1] - p0[1];
  const dist = Math.sqrt(dx * dx + dy * dy);
  // Perpendicular offset: proportional to distance, capped to avoid
  // excessive curvature on very long arcs. Negative ny pushes the arc
  // upward (toward lower y) on screen, giving a consistent visual curve.
  const curvature = Math.min(dist * 0.2, 80);
  const nx = -dy / (dist || 1);
  const ny = dx / (dist || 1);
  const cx = mx + nx * curvature;
  const cy = my + ny * curvature;

  // Build the SVG path string.
  // Unilateral arcs need explicit vertices for marker-mid placement (SVG
  // only places marker-mid at interior vertices of a polyline, not along
  // smooth curves). Sample ~10 points along the Bézier for these.
  // Non-unilateral arcs use a native SVG quadratic Bézier for smoothness.
  let d;
  if (isUnilateral) {
    const numSeg = 10;
    const pts = [];
    for (let i = 0; i <= numSeg; i++) {
      const t = i / numSeg;
      const u = 1 - t;
      // Quadratic Bézier: B(t) = (1-t)²·P0 + 2(1-t)t·C + t²·P1
      const bx = u * u * p0[0] + 2 * u * t * cx + t * t * p1[0];
      const by = u * u * p0[1] + 2 * u * t * cy + t * t * p1[1];
      pts.push(`${bx.toFixed(2)},${by.toFixed(2)}`);
    }
    d = `M${pts[0]} L${pts.slice(1).join(" L")}`;
  } else {
    d = `M${p0[0].toFixed(2)},${p0[1].toFixed(2)} Q${cx.toFixed(2)},${cy.toFixed(2)} ${p1[0].toFixed(2)},${p1[1].toFixed(2)}`;
  }

  const arcPath = arcGroup.append("path")
    .attr("class", "arc")
    .attr("d", d)
    .attr("stroke", color)
    .style("--arc-color", color)
    .attr("stroke-width", 0.4 / currentZoomK())
    .style("fill", "none")
    .attr("opacity", 0.65)
    .attr("data-agreement-id", agreement.id);

  if (isDashed) {
    arcPath.attr("stroke-dasharray", "6,4");
  }

  // Unilateral arcs get repeated arrows along the path (marker-mid)
  // and an arrowhead at the end (marker-end)
  if (isUnilateral) {
    arcPath.attr("marker-mid", `url(#arrow-mid-${agreement.category})`);
    arcPath.attr("marker-end", `url(#arrow-${agreement.category})`);
  }

  // Hover
  arcPath.on("mouseenter", function(event) {
    d3.select(this).attr("opacity", 1);
    showTooltip(event, agreement, fromCode, toCode);
  });

  arcPath.on("mousemove", function(event) {
    moveTooltip(event);
  });

  arcPath.on("mouseleave", function() {
    d3.select(this).attr("opacity", 0.65);
    hideTooltip();
  });

  arcPath.on("click", function(event) {
    event.stopPropagation();
    showInfoPanel(agreement);
  });
}

// ── Interactions ───────────────────────────────────────────────────

function setupInteractions() {
  // Country hover
  countryPaths
    .on("mouseenter", function(event) {
      const el = d3.select(this);
      el.classed("country-highlighted", true);
      const iso2 = el.attr("data-iso2");
      const count = el.attr("data-count") || 0;
      const name = COUNTRY_NAMES[iso2] || iso2 || "Unknown";

      const tooltip = document.getElementById("tooltip");
      tooltip.innerHTML = `<div class="tt-name">${escapeHtml(name)}</div>
        <div class="tt-row">${count} agreement${count !== "1" ? "s" : ""}</div>`;
      tooltip.style.display = "block";
      moveTooltip(event);
    })
    .on("mousemove", function(event) {
      moveTooltip(event);
    })
    .on("mouseleave", function() {
      d3.select(this).classed("country-highlighted", false);
      hideTooltip();
    })
    .on("click", function(event) {
      event.stopPropagation();
      const iso2 = d3.select(this).attr("data-iso2");
      if (iso2) {
        const select = document.getElementById("country-filter");
        select.value = iso2;
        filters.country = iso2;
        render();
        showCountryPanel(iso2);
      }
    });

  // Click on background to dismiss info panel
  svg.on("click", function() {
    document.getElementById("info-panel").style.display = "none";
  });

  // Sidebar toggle (mobile)
  document.getElementById("sidebar-toggle").addEventListener("click", () => {
    document.getElementById("sidebar").classList.toggle("open");
  });
}

// ── Tooltip & Info Panel ───────────────────────────────────────────

function showTooltip(event, agreement, fromCode, toCode) {
  const tooltip = document.getElementById("tooltip");
  const cat = CATEGORY_LABELS[agreement.category] || agreement.category;
  const allP = getAllParties(agreement);
  const parties = allP.map(p => COUNTRY_NAMES[p] || p).join(", ");
  const year = agreement.year_signed || agreement.year_operational || "N/A";

  tooltip.innerHTML = `
    <div class="tt-name">${escapeHtml(agreement.name)}</div>
    <div class="tt-cat" style="color:${CATEGORY_COLORS[agreement.category]}">${escapeHtml(cat)}</div>
    <div class="tt-row"><strong>Parties:</strong> ${escapeHtml(parties)}</div>
    <div class="tt-row"><strong>Year:</strong> ${escapeHtml(String(year))}</div>
    <div class="tt-row"><strong>Status:</strong> ${escapeHtml(agreement.status)}</div>
  `;
  tooltip.style.display = "block";
  moveTooltip(event);
}

function moveTooltip(event) {
  const tooltip = document.getElementById("tooltip");
  const container = document.getElementById("map-container");
  const rect = container.getBoundingClientRect();
  let x = event.clientX - rect.left + 14;
  let y = event.clientY - rect.top + 14;

  // Keep tooltip in bounds
  const tw = tooltip.offsetWidth;
  const th = tooltip.offsetHeight;
  if (x + tw > rect.width - 10) x = x - tw - 28;
  if (y + th > rect.height - 10) y = y - th - 28;

  tooltip.style.left = x + "px";
  tooltip.style.top = y + "px";
}

function hideTooltip() {
  document.getElementById("tooltip").style.display = "none";
}

function showCountryPanel(iso2) {
  const panel = document.getElementById("info-panel");
  const countryName = COUNTRY_NAMES[iso2] || iso2;

  // Find all agreements involving this country
  const allMatching = agreements.filter(a => {
    const allP = getAllParties(a);
    if (allP.includes(iso2)) return true;
    // If country is an EU member, also include EU-level agreements
    if (entities.EU && entities.EU.fill_countries.includes(iso2) && allP.includes("EU")) return true;
    return false;
  });

  // Apply active filters (category, year range, status)
  const matching = allMatching.filter(a => passesFilters(a));

  const totalCount = allMatching.length;
  const filteredCount = matching.length;
  const filtersNarrow = filteredCount < totalCount;

  let html = `<span class="ip-close" onclick="document.getElementById('info-panel').style.display='none'">&times;</span>`;
  html += `<div class="ip-name">${escapeHtml(countryName)}</div>`;
  if (filtersNarrow) {
    html += `<div class="ip-row" style="margin-bottom:10px;color:#666;">Showing ${filteredCount} of ${totalCount} agreement${totalCount !== 1 ? "s" : ""}</div>`;
  } else {
    html += `<div class="ip-row" style="margin-bottom:10px;color:#666;">${totalCount} agreement${totalCount !== 1 ? "s" : ""}</div>`;
  }

  if (matching.length === 0) {
    html += `<div class="ip-row" style="color:#888;">No agreements found.</div>`;
  } else {
    matching.forEach(a => {
      const cat = CATEGORY_LABELS[a.category] || a.category;
      const color = CATEGORY_COLORS[a.category] || "#666";
      const year = a.year_signed || a.year_operational || "";
      const safeId = escapeHtml(a.id);
      html += `<div class="country-panel-entry" style="padding:6px 0;border-bottom:1px solid #eee;cursor:pointer;" data-agreement-id="${safeId}">`;
      html += `<div style="font-weight:600;font-size:12px;">${escapeHtml(a.name)}</div>`;
      html += `<span style="display:inline-block;padding:1px 6px;border-radius:3px;font-size:10px;text-transform:uppercase;color:#fff;background:${color};margin-top:2px;">${escapeHtml(cat)}</span>`;
      if (year) html += `<span style="font-size:11px;color:#888;margin-left:6px;">${escapeHtml(String(year))}</span>`;
      html += `</div>`;
    });
  }

  panel.innerHTML = html;
  // Wire up click handlers via event delegation (avoids inline onclick injection)
  panel.querySelectorAll(".country-panel-entry[data-agreement-id]").forEach(entry => {
    entry.addEventListener("click", () => {
      const id = entry.getAttribute("data-agreement-id");
      const a = agreements.find(x => x.id === id);
      if (a) showInfoPanel(a);
    });
  });
  panel.style.display = "block";
}

function showInfoPanel(agreement) {
  const panel = document.getElementById("info-panel");
  const cat = CATEGORY_LABELS[agreement.category] || agreement.category;
  const allP = getAllParties(agreement);
  const parties = allP.map(p => COUNTRY_NAMES[p] || p).join(", ");
  const yearSigned = agreement.year_signed || "N/A";
  const yearOp = agreement.year_operational || "N/A";
  const color = CATEGORY_COLORS[agreement.category] || "#666";

  let html = `<span class="ip-close" onclick="document.getElementById('info-panel').style.display='none'">&times;</span>`;
  html += `<div class="ip-name">${escapeHtml(agreement.name)}</div>`;
  html += `<span class="ip-cat" style="background:${color}">${escapeHtml(cat)}</span>`;
  html += `<div class="ip-row"><span class="ip-label">Parties:</span> ${escapeHtml(parties)}</div>`;
  html += `<div class="ip-row"><span class="ip-label">Year Signed:</span> ${escapeHtml(String(yearSigned))}</div>`;
  html += `<div class="ip-row"><span class="ip-label">Year Operational:</span> ${escapeHtml(String(yearOp))}</div>`;
  html += `<div class="ip-row"><span class="ip-label">Status:</span> ${escapeHtml(agreement.status)}</div>`;
  html += `<div class="ip-row"><span class="ip-label">Directionality:</span> ${escapeHtml(agreement.directionality || "bilateral")}</div>`;

  if (agreement.description) {
    html += `<div class="ip-desc">${escapeHtml(agreement.description)}</div>`;
  }
  const sourceUrl = agreement.source_url || agreement.source;
  if (sourceUrl) {
    html += `<div class="ip-row" style="margin-top:8px;"><a href="${escapeHtml(sourceUrl)}" target="_blank" rel="noopener">Source</a></div>`;
  }

  panel.innerHTML = html;
  panel.style.display = "block";
}

// ── Utilities ──────────────────────────────────────────────────────

function debounce(fn, ms) {
  let timer;
  return (...args) => { clearTimeout(timer); timer = setTimeout(() => fn(...args), ms); };
}

function escapeHtml(str) {
  const div = document.createElement("div");
  div.textContent = str;
  return div.innerHTML;
}

// ── Tabs ──────────────────────────────────────────────────────────

function initTabs() {
  const buttons = document.querySelectorAll(".tab-btn");
  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      // Deactivate all tabs
      buttons.forEach(b => b.classList.remove("active"));
      document.querySelectorAll(".tab-content").forEach(c => c.style.display = "none");
      // Activate clicked tab
      btn.classList.add("active");
      document.getElementById("tab-" + btn.dataset.tab).style.display = "block";
      // Build agreements table on first view
      if (btn.dataset.tab === "agreements" && !window._agreementsTableBuilt) {
        buildAgreementsTable();
        window._agreementsTableBuilt = true;
      }
    });
  });

  // Populate guide colors list
  const colorList = document.getElementById("guide-colors");
  if (colorList) {
    Object.entries(CATEGORY_COLORS).forEach(([cat, color]) => {
      const li = document.createElement("li");
      li.innerHTML = `<span class="color-indicator" style="background:${color};"></span>${CATEGORY_LABELS[cat] || cat}`;
      colorList.appendChild(li);
    });
  }
}

function buildAgreementsTable() {
  const tbody = document.getElementById("agreements-tbody");
  if (!tbody) return;

  // Sort by year descending (newest first)
  const sorted = [...agreements].sort((a, b) => {
    const ya = a.year_signed || a.year_operational || 0;
    const yb = b.year_signed || b.year_operational || 0;
    return yb - ya;
  });

  function renderRows(data) {
    tbody.innerHTML = "";
    data.forEach(a => {
      const cat = CATEGORY_LABELS[a.category] || a.category;
      const color = CATEGORY_COLORS[a.category] || "#666";
      const year = a.year_signed || a.year_operational || "N/A";
      const allP = getAllParties(a);
      const partiesStr = allP.map(p => COUNTRY_NAMES[p] || p).join(", ");
      const truncated = partiesStr.length > 60 ? partiesStr.slice(0, 57) + "..." : partiesStr;

      const tr = document.createElement("tr");
      tr.innerHTML = `<td>${escapeHtml(a.name)}</td>` +
        `<td><span class="cat-badge" style="background:${color}">${escapeHtml(cat)}</span></td>` +
        `<td>${escapeHtml(String(year))}</td>` +
        `<td>${escapeHtml(a.status)}</td>` +
        `<td title="${escapeHtml(partiesStr)}">${escapeHtml(truncated)}</td>`;
      tbody.appendChild(tr);
    });
  }

  renderRows(sorted);

  // Shared state for search + sort composition
  let currentSort = { col: "year", asc: false };
  const searchInput = document.getElementById("agreements-search");

  function getFilteredAndSorted() {
    const q = searchInput.value.toLowerCase().trim();
    let data = sorted;
    if (q) {
      data = data.filter(a => {
        const allP = getAllParties(a);
        const partiesStr = allP.map(p => COUNTRY_NAMES[p] || p).join(", ");
        const cat = CATEGORY_LABELS[a.category] || a.category;
        const year = String(a.year_signed || a.year_operational || "");
        const searchable = [a.name, cat, year, a.status, partiesStr].join(" ").toLowerCase();
        return searchable.includes(q);
      });
    }
    const dir = currentSort.asc ? 1 : -1;
    return [...data].sort((a, b) => {
      let va, vb;
      switch (currentSort.col) {
        case "name": va = a.name; vb = b.name; break;
        case "category": va = a.category; vb = b.category; break;
        case "year":
          va = a.year_signed || a.year_operational || 0;
          vb = b.year_signed || b.year_operational || 0;
          return (va - vb) * dir;
        case "status": va = a.status; vb = b.status; break;
        case "parties":
          va = getAllParties(a).map(p => COUNTRY_NAMES[p] || p).join(", ");
          vb = getAllParties(b).map(p => COUNTRY_NAMES[p] || p).join(", ");
          break;
        default: return 0;
      }
      return String(va).localeCompare(String(vb)) * dir;
    });
  }

  // Search filter
  searchInput.addEventListener("input", () => {
    renderRows(getFilteredAndSorted());
  });

  // Column sort
  document.querySelectorAll("#agreements-table th[data-sort]").forEach(th => {
    th.addEventListener("click", () => {
      const col = th.dataset.sort;
      if (currentSort.col === col) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort.col = col;
        currentSort.asc = true;
      }
      renderRows(getFilteredAndSorted());
    });
  });
}

// ── Start ──────────────────────────────────────────────────────────

document.addEventListener("DOMContentLoaded", () => {
  init();
  initTabs();
});
</script>

