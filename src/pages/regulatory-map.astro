<script is:inline>
  // Nav tooltip (same as other pages)
  const navTooltip = document.createElement("div");
  navTooltip.className = "nav-tooltip";
  navTooltip.style.display = "none";
  document.body.appendChild(navTooltip);

  document.querySelectorAll(".nav-link[data-nav-tip]").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const tip = link.dataset.navTip;
      if (!tip) return;
      navTooltip.textContent = tip;
      navTooltip.style.display = "block";
      const rect = link.getBoundingClientRect();
      const pad = 4;
      let x = rect.left;
      const y = rect.bottom + pad;
      const tw = navTooltip.offsetWidth;
      if (x + tw > window.innerWidth - pad) x = window.innerWidth - tw - pad;
      navTooltip.style.left = x + "px";
      navTooltip.style.top = y + "px";
    });
    link.addEventListener("mouseleave", () => {
      navTooltip.style.display = "none";
    });
  });

  // Offset map below fixed nav
  const navEl = document.querySelector(".top-nav");
  function updateMapLayout() {
    const navH = navEl.offsetHeight;
    const regMap = document.querySelector(".reg-map");
    if (regMap) {
      regMap.style.paddingTop = navH + "px";
    }
  }
  updateMapLayout();
  window.addEventListener("resize", updateMapLayout);
</script>
