---
import Layout from "../layouts/Layout.astro";
import PipelineContent from "../content/methods_updated.md";
---

<Layout title="Methods">
  <nav class="top-nav">
    <div class="nav-left">
      <a href="/drugs" class="site-name">JURISCRIPTION</a>
      <a href="/drugs" class="nav-link">MAIN DATASET</a>
      <a href="/results" class="nav-link">RESULTS</a>
      <a href="/methods" class="nav-link active">METHODS</a>
      <a href="/fda-to-mhra" class="nav-link" data-nav-tip="This sheet matches each drug in the FDA dataset to the closest drug (based on ingredients and dosage) in the MHRA dataset.">FDA → MHRA</a>
      <a href="/mhra-to-fda" class="nav-link" data-nav-tip="This sheet matches each drug in the MHRA dataset to the closest drug (based on ingredients and dosage) in the FDA dataset.">MHRA → FDA</a>
    </div>
  </nav>

  <div class="methods-body">
    <PipelineContent />
  </div>
</Layout>

<script>
  const navTooltip = document.createElement("div");
  navTooltip.className = "nav-tooltip";
  navTooltip.style.display = "none";
  document.body.appendChild(navTooltip);

  document.querySelectorAll(".methods-body table").forEach((table) => {
    const wrapper = document.createElement("div");
    wrapper.className = "table-scroll";
    table.parentNode!.insertBefore(wrapper, table);
    wrapper.appendChild(table);
  });

  document.querySelectorAll(".nav-link[data-nav-tip]").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const tip = (link as HTMLElement).dataset.navTip;
      if (!tip) return;
      navTooltip.textContent = tip;
      navTooltip.style.display = "block";
      const rect = (link as HTMLElement).getBoundingClientRect();
      const pad = 4;
      let x = rect.left;
      const y = rect.bottom + pad;
      const tw = navTooltip.offsetWidth;
      if (x + tw > window.innerWidth - pad) x = window.innerWidth - tw - pad;
      navTooltip.style.left = x + "px";
      navTooltip.style.top = y + "px";
    });
    link.addEventListener("mouseleave", () => {
      navTooltip.style.display = "none";
    });
  });
</script>

<style is:global>
  /* ===== Top Navigation ===== */
  .top-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #ccc;
    background: white;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-name {
    font-weight: 700;
    border: 1px solid #333;
    padding: 0.15rem 0.5rem;
    color: var(--color-black);
    text-decoration: none;
  }

  .site-name:hover {
    border-color: black;
  }

  .nav-link {
    color: var(--color-black);
    text-decoration: none;
  }

  .nav-link.active {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .nav-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ===== Page body ===== */
  html, body {
    background: white !important;
    color: var(--color-black);
  }

  .methods-body {
    max-width: 780px;
    margin: 0 auto;
    padding: 6rem 2rem 6rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-black);
  }

  /* ===== Prose styles for markdown content ===== */
  .methods-body h1 {
    font-family: var(--font-mono);
    font-size: 1.0rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .methods-body h2 {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 700;
    margin: 2.5rem 0 0.75rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-accent);
  }

  .methods-body h2:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .methods-body h3 {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    font-weight: 700;
    margin: 1.75rem 0 0.5rem;
  }

  .methods-body h4 {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 700;
    margin: 1.25rem 0 0.4rem;
  }

  .methods-body p {
    margin-bottom: 1rem;
  }

  .methods-body hr {
    border: none;
    border-top: 1px solid #ddd;
    margin: 2rem 0;
  }

  .methods-body strong {
    font-weight: 700;
  }

  .methods-body em {
    font-style: italic;
  }

  .methods-body ul,
  .methods-body ol {
    margin: 0.75rem 0 1rem 1.5rem;
    padding: 0;
  }

  .methods-body li {
    margin-bottom: 0.3rem;
  }

  /* ===== Tables ===== */
  .table-scroll {
    overflow-x: auto;
    width: 100%;
    margin: 1rem 0 1.5rem;
  }

  .methods-body table {
    border-collapse: collapse;
    width: max-content;
    min-width: 100%;
    margin: 0;
    font-size: 0.82rem;
  }

  .methods-body th {
    text-align: left;
    border-bottom: 2px solid #333;
    padding: 0.3rem 0.75rem 0.3rem 0.4rem;
    font-weight: 700;
    background: #eef4f0;
  }

  .methods-body td {
    border-bottom: 1px solid #e0e0e0;
    padding: 0.3rem 0.75rem 0.3rem 0;
    vertical-align: top;
  }

  .methods-body tr:last-child td {
    border-bottom: none;
  }

  /* ===== Code blocks ===== */
  .methods-body pre {
    background: #f6f6f6;
    border: 1px solid #ddd;
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0 1.5rem;
    font-size: 0.78rem;
    line-height: 1.6;
    display: flex;
    justify-content: center;
  }

  .methods-body code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    background: #f2f2f2;
    padding: 0.1em 0.3em;
    border-radius: 2px;
  }

  .methods-body pre code {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  /* ===== Nav Tooltip ===== */
  .nav-tooltip {
    position: fixed;
    z-index: 200;
    max-width: 300px;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.5;
    pointer-events: none;
    border: 1px solid #ccc;
    background: var(--color-grey);
    color: var(--color-black);
  }
</style>
