---
import Layout from "../layouts/Layout.astro";
---

<Layout title="MHRA → FDA Matches">
  <nav class="top-nav">
    <div class="nav-left">
      <a href="/drugs" class="site-name">JURISCRIPTION</a>
      <a href="/drugs" class="nav-link">MAIN DATASET</a>
      <a href="/fda-to-mhra" class="nav-link" data-nav-tip="This sheet matches each drug in the FDA dataset to the closest drug (based on ingredients and dosage) in the MHRA dataset.">FDA → MHRA</a>
      <a href="/mhra-to-fda" class="nav-link active" data-nav-tip="This sheet matches each drug in the MHRA dataset to the closest drug (based on ingredients and dosage) in the FDA dataset.">MHRA → FDA</a>
      <span class="nav-sep">|</span>
      <a href="/results" class="nav-link">RESULTS</a>
      <a href="/methods" class="nav-link">METHODOLOGY</a>
    </div>
  </nav>

  <!-- Confidence guide modal -->
  <div class="conf-modal-overlay" id="conf-modal">
    <div class="conf-modal">
      <h2>Understanding Confidence Levels</h2>
      <p class="conf-modal-note">In this dataset each MHRA product is matched with the most similar FDA product.</p>
      <ul class="conf-modal-list">
        <li><span class="legend-dot dot-high"></span><strong>High</strong> — The ingredients and dosage strength are perfectly matched. We are confident this drug is available in both jurisdictions.</li>
        <li><span class="legend-dot dot-medium"></span><strong>Medium</strong> — The ingredients match but the dosage is not a perfect match.</li>
        <li><span class="legend-dot dot-low"></span><strong>Low</strong> — Partial or approximate match. We have low confidence that this drug is approved in both jurisdictions.</li>
        <li><span class="legend-dot dot-none"></span><strong>No Match</strong> — No sufficiently similar drug could be found in the target dataset.</li>
      </ul>
      <p class="conf-modal-note">For cases where one input drug had multiple matches, the best match is presented whilst the others can be viewed by selecting the dropdown arrow ▾.</p>
      <p class="conf-modal-note">For more details, please see the <a href="/methods">methodology section</a>.</p>
      <div class="conf-modal-actions">
        <button class="conf-modal-btn" id="conf-modal-close">I understand</button>
        <button class="conf-modal-btn-secondary" id="conf-modal-dismiss">Don't show again</button>
      </div>
    </div>
  </div>

  <div class="toolbar">
    <input
      type="text"
      id="search"
      placeholder="Search by source or matched product name"
      autocomplete="off"
    />
    <div class="toolbar-right">
      <span id="result-count" class="result-count"></span>
      <span class="conf-legend">
        <button class="legend-item active" data-conf="HIGH"><span class="legend-dot dot-high"></span>HIGH</button>
        <button class="legend-item active" data-conf="MEDIUM"><span class="legend-dot dot-medium"></span>MEDIUM</button>
        <button class="legend-item active" data-conf="LOW"><span class="legend-dot dot-low"></span>LOW</button>
        <button class="legend-item active" data-conf="NONE"><span class="legend-dot dot-none"></span>NO MATCH</button>
      </span>
    </div>
  </div>

  <div id="loading" class="loading">
    <div class="spinner"></div>
    <p>Loading match data...</p>
  </div>

  <div class="table-wrapper" id="table-wrapper" style="display:none">
    <table>
      <thead>
        <tr>
          <th class="col-source-product" data-sort="a" data-col-tip="The brand or trade name of the drug as listed in the MHRA marketing authorisations.">MHRA Product<span class="sort-icon"> ↕</span></th>
          <th data-sort="b" data-col-tip="The International Nonproprietary Name(s) — the generic active ingredient(s) of the MHRA source product.">INN Ingredient(s)<span class="sort-icon"> ↕</span></th>
          <th class="col-strength" data-sort="c" data-col-tip="The dose or concentration of the active ingredient(s) in the MHRA product.">MHRA Strength<span class="sort-icon"> ↕</span></th>
          <th class="col-matched-product" data-sort="d" data-col-tip="The FDA-approved product judged most similar to the MHRA source, scored on ingredient and strength similarity.">Closest Matched FDA Product<span class="sort-icon"> ↕</span></th>
          <th data-sort="e" data-col-tip="The active ingredient(s) of the matched FDA product.">Matched INN Ingredient(s)<span class="sort-icon"> ↕</span></th>
          <th class="col-strength" data-sort="f" data-col-tip="The dose or concentration of the matched FDA product.">Matched Strength<span class="sort-icon"> ↕</span></th>
          <th class="col-confidence" data-col-tip="Match quality: HIGH = exact ingredient and close strength; MEDIUM = same ingredient, weaker strength match; LOW = partial or approximate match.">Confidence</th>
        </tr>
      </thead>
      <tbody id="table-body"></tbody>
    </table>
    <div id="scroll-sentinel" class="scroll-sentinel"></div>
    <div id="load-more-indicator" class="load-more-indicator" style="display:none">
      <div class="spinner"></div>
    </div>
    <div id="end-of-results" class="end-of-results" style="display:none">
      End of results
    </div>
  </div>
</Layout>

<script>
  const BATCH_SIZE = 50;

  type Rec = Record<string, any>;
  interface Group { primary: Rec; secondaries: Rec[]; autoExpand: boolean; }

  let allRecords: Rec[] = [];
  let allGroups: Group[] = [];
  let renderedGroups: Group[] = [];
  let renderedCount = 0;
  let currentSearch = "";
  let sortField = "a";
  let sortAsc = true;
  let debounceTimer: any = null;
  let loading = false;

  const searchInput = document.getElementById("search") as HTMLInputElement;
  const tableWrapper = document.getElementById("table-wrapper")!;
  const tableBody = document.getElementById("table-body")!;
  const loadingEl = document.getElementById("loading")!;
  const resultCount = document.getElementById("result-count")!;
  const sortHeaders = document.querySelectorAll("th[data-sort]");
  const scrollSentinel = document.getElementById("scroll-sentinel")!;
  const loadMoreIndicator = document.getElementById("load-more-indicator")!;
  const endOfResults = document.getElementById("end-of-results")!;

  // Confidence modal
  const confModal = document.getElementById("conf-modal") as HTMLElement;
  if (localStorage.getItem("conf-modal-dismissed") === "true") {
    confModal.style.display = "none";
  }
  document.getElementById("conf-modal-close")!.addEventListener("click", () => {
    confModal.style.display = "none";
  });
  document.getElementById("conf-modal-dismiss")!.addEventListener("click", () => {
    localStorage.setItem("conf-modal-dismissed", "true");
    confModal.style.display = "none";
  });

  const navEl = document.querySelector(".top-nav") as HTMLElement;
  const toolbarEl = document.querySelector(".toolbar") as HTMLElement;

  // Confidence filter state — all active by default
  const activeFilters = new Set<string>(["HIGH", "MEDIUM", "LOW", "NONE"]);
  const legendButtons = document.querySelectorAll<HTMLElement>(".legend-item[data-conf]");

  legendButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const conf = btn.dataset.conf!;
      if (activeFilters.has(conf)) {
        if (activeFilters.size === 1) {
          activeFilters.add("HIGH");
          activeFilters.add("MEDIUM");
          activeFilters.add("LOW");
          activeFilters.add("NONE");
          legendButtons.forEach((b) => b.classList.add("active"));
        } else {
          activeFilters.delete(conf);
          btn.classList.remove("active");
        }
      } else {
        activeFilters.add(conf);
        btn.classList.add("active");
      }
      applyFilters();
    });
  });

  function updateHeaderLayout() {
    const navH = navEl.offsetHeight;
    const toolbarH = toolbarEl.offsetHeight;
    const totalH = navH + toolbarH;
    toolbarEl.style.top = navH + "px";
    document.body.style.paddingTop = totalH + "px";
    document.querySelectorAll("thead th").forEach((th) => {
      (th as HTMLElement).style.top = totalH + "px";
    });
  }
  updateHeaderLayout();
  window.addEventListener("resize", updateHeaderLayout);

  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting && !loading && renderedCount < renderedGroups.length) {
        loadMore();
      }
    },
    { rootMargin: "400px" }
  );

  fetch("/mhra-to-fda-index.json")
    .then((r) => r.json())
    .then((data) => {
      allRecords = data;
      allGroups = buildGroups(allRecords);
      loadingEl.style.display = "none";
      tableWrapper.style.display = "block";
      updateHeaderLayout();
      applyFilters();
      observer.observe(scrollSentinel);
    })
    .catch((err) => {
      loadingEl.innerHTML = `<p style="color:#C7262C">Failed to load match data. Please refresh.</p>`;
      console.error(err);
    });

  searchInput.addEventListener("input", () => {
    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      currentSearch = searchInput.value.trim().toLowerCase();
      applyFilters();
    }, 150);
  });

  sortHeaders.forEach((th) => {
    th.addEventListener("click", () => {
      const field = (th as HTMLElement).dataset.sort!;
      if (!field) return;
      if (sortField === field) {
        sortAsc = !sortAsc;
      } else {
        sortField = field;
        sortAsc = true;
      }
      sortHeaders.forEach((h) => {
        const icon = h.querySelector(".sort-icon");
        if (icon) {
          if ((h as HTMLElement).dataset.sort === sortField) {
            icon.textContent = sortAsc ? " ↑" : " ↓";
          } else {
            icon.textContent = " ↕";
          }
        }
      });
      applySort();
      resetAndRender();
    });
  });

  // Toggle secondary rows via event delegation
  tableBody.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest(".toggle-btn") as HTMLElement | null;
    if (!btn) return;
    const groupId = btn.dataset.group!;
    const count = btn.dataset.count!;
    const expanded = btn.getAttribute("aria-expanded") === "true";
    const newExpanded = !expanded;
    btn.setAttribute("aria-expanded", String(newExpanded));
    btn.textContent = (newExpanded ? "▼" : "▶") + " +" + count;
    tableBody.querySelectorAll<HTMLTableRowElement>(`tr.secondary-row[data-group="${groupId}"]`).forEach((tr) => {
      tr.style.display = newExpanded ? "" : "none";
    });
  });

  function buildGroups(records: Rec[]): Group[] {
    const map = new Map<string, Group>();
    for (const rec of records) {
      const key = (rec.a || "").toLowerCase();
      if (!map.has(key)) {
        map.set(key, { primary: rec, secondaries: [], autoExpand: false });
      } else {
        const g = map.get(key)!;
        if ((rec.t ?? 0) > (g.primary.t ?? 0)) {
          g.secondaries.push(g.primary);
          g.primary = rec;
        } else {
          g.secondaries.push(rec);
        }
      }
    }
    return Array.from(map.values());
  }

  function recMatchesQuery(rec: Rec, query: string): boolean {
    return (
      (rec.a || "").toLowerCase().includes(query) ||
      (rec.d || "").toLowerCase().includes(query) ||
      (rec.b || "").toLowerCase().includes(query) ||
      (rec.e || "").toLowerCase().includes(query)
    );
  }

  function applyFilters() {
    const query = currentSearch;
    const confFiltered =
      activeFilters.size === 4
        ? allGroups
        : allGroups.filter((g) => activeFilters.has(g.primary.k || ""));

    if (query) {
      renderedGroups = [];
      for (const g of confFiltered) {
        const primaryMatches = recMatchesQuery(g.primary, query);
        const anySecondaryMatches = g.secondaries.some((r) => recMatchesQuery(r, query));
        if (primaryMatches || anySecondaryMatches) {
          renderedGroups.push({ ...g, autoExpand: !primaryMatches && anySecondaryMatches });
        }
      }
    } else {
      renderedGroups = confFiltered.map((g) => ({ ...g, autoExpand: false }));
    }
    applySort();
    resetAndRender();
  }

  function applySort() {
    renderedGroups.sort((a, b) => {
      const va = (a.primary[sortField] || "").toLowerCase();
      const vb = (b.primary[sortField] || "").toLowerCase();
      if (va < vb) return sortAsc ? -1 : 1;
      if (va > vb) return sortAsc ? 1 : -1;
      return 0;
    });
  }

  function resetAndRender() {
    renderedCount = 0;
    tableBody.innerHTML = "";
    endOfResults.style.display = "none";
    const totalMatches = renderedGroups.reduce((acc, g) => acc + 1 + g.secondaries.length, 0);
    resultCount.textContent = totalMatches.toLocaleString() + " matches";
    if (renderedGroups.length === 0) {
      tableBody.innerHTML = `<tr><td colspan="7" class="empty-state">No matches found.</td></tr>`;
      return;
    }
    loadMore();
  }

  function loadMore() {
    if (loading || renderedCount >= renderedGroups.length) return;
    loading = true;
    loadMoreIndicator.style.display = "block";

    requestAnimationFrame(() => {
      const end = Math.min(renderedCount + BATCH_SIZE, renderedGroups.length);
      const fragment = document.createDocumentFragment();

      for (let i = renderedCount; i < end; i++) {
        const g = renderedGroups[i];
        const groupId = "g" + i + "_" + renderedCount;
        appendGroupRows(fragment, g, groupId);
      }

      tableBody.appendChild(fragment);
      renderedCount = end;
      loading = false;
      loadMoreIndicator.style.display = "none";

      if (renderedCount >= renderedGroups.length) {
        endOfResults.style.display = "block";
      }
    });
  }

  function confClass(rec: Rec): string {
    const k = rec.k || "";
    if (k === "HIGH") return "conf-high";
    if (k === "MEDIUM") return "conf-medium";
    if (k === "LOW") return "conf-low";
    if (k === "NONE") return "conf-none";
    return "";
  }

  function confBadge(rec: Rec): string {
    const k = rec.k || "";
    if (!k) return "&mdash;";
    return `<span class="conf-badge conf-badge-${k.toLowerCase()}">${k}</span>`;
  }

  function appendGroupRows(fragment: DocumentFragment, g: Group, groupId: string) {
    // Primary row
    const primaryTr = document.createElement("tr");
    const cc = confClass(g.primary);
    if (cc) primaryTr.classList.add(cc);

    let toggleBtn = "";
    if (g.secondaries.length > 0) {
      const count = g.secondaries.length;
      const expanded = g.autoExpand;
      toggleBtn = `<button class="toggle-btn" data-group="${groupId}" data-count="${count}" aria-expanded="${expanded}">${expanded ? "▼" : "▶"} +${count}</button>`;
    }

    primaryTr.innerHTML = `
      <td class="col-source-product"><div class="source-cell"><div class="product-name">${esc(g.primary.a || "")}</div>${toggleBtn ? `<div class="toggle-row">${toggleBtn}</div>` : ""}</div></td>
      <td>${esc(g.primary.b || "") || "&mdash;"}</td>
      <td class="col-strength">${esc(g.primary.c || "") || "&mdash;"}</td>
      <td class="col-matched-product"><div class="product-name">${esc(g.primary.d || "") || "&mdash;"}</div></td>
      <td>${esc(g.primary.e || "") || "&mdash;"}</td>
      <td class="col-strength">${esc(g.primary.f || "") || "&mdash;"}</td>
      <td class="col-confidence">${confBadge(g.primary)}</td>`;
    fragment.appendChild(primaryTr);

    // Secondary rows
    for (const sec of g.secondaries) {
      const secTr = document.createElement("tr");
      const scc = confClass(sec);
      if (scc) secTr.classList.add(scc);
      secTr.classList.add("secondary-row");
      secTr.dataset.group = groupId;
      if (!g.autoExpand) secTr.style.display = "none";

      secTr.innerHTML = `
        <td class="col-source-product"><div class="product-name secondary-name">↳ ${esc(sec.a || "")}</div></td>
        <td>${esc(sec.b || "") || "&mdash;"}</td>
        <td class="col-strength">${esc(sec.c || "") || "&mdash;"}</td>
        <td class="col-matched-product"><div class="product-name">${esc(sec.d || "") || "&mdash;"}</div></td>
        <td>${esc(sec.e || "") || "&mdash;"}</td>
        <td class="col-strength">${esc(sec.f || "") || "&mdash;"}</td>
        <td class="col-confidence">${confBadge(sec)}</td>`;
      fragment.appendChild(secTr);
    }
  }

  function esc(str: string): string {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }

  // Column header tooltips
  const colTooltip = document.createElement("div");
  colTooltip.className = "col-tooltip";
  colTooltip.style.display = "none";
  document.body.appendChild(colTooltip);

  document.querySelectorAll("th[data-col-tip]").forEach((th) => {
    th.addEventListener("mouseenter", () => {
      const tip = (th as HTMLElement).dataset.colTip;
      if (!tip) return;
      colTooltip.textContent = tip;
      colTooltip.style.display = "block";
      const rect = (th as HTMLElement).getBoundingClientRect();
      const pad = 4;
      let x = rect.left;
      const y = rect.bottom + pad;
      const tw = colTooltip.offsetWidth;
      if (x + tw > window.innerWidth - pad) x = window.innerWidth - tw - pad;
      colTooltip.style.left = x + "px";
      colTooltip.style.top = y + "px";
    });
    th.addEventListener("mouseleave", () => {
      colTooltip.style.display = "none";
    });
  });

  // Nav link tooltips
  const navTooltip = document.createElement("div");
  navTooltip.className = "nav-tooltip";
  navTooltip.style.display = "none";
  document.body.appendChild(navTooltip);

  document.querySelectorAll(".nav-link[data-nav-tip]").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const tip = (link as HTMLElement).dataset.navTip;
      if (!tip) return;
      navTooltip.textContent = tip;
      navTooltip.style.display = "block";
      const rect = (link as HTMLElement).getBoundingClientRect();
      const pad = 4;
      let x = rect.left;
      const y = rect.bottom + pad;
      const tw = navTooltip.offsetWidth;
      if (x + tw > window.innerWidth - pad) x = window.innerWidth - tw - pad;
      navTooltip.style.left = x + "px";
      navTooltip.style.top = y + "px";
    });
    link.addEventListener("mouseleave", () => {
      navTooltip.style.display = "none";
    });
  });
</script>

<style is:global>
  /* ===== Top Navigation ===== */
  .top-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #ccc;
    background: white;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-name {
    font-weight: 700;
    border: 1px solid #333;
    padding: 0.15rem 0.5rem;
    color: var(--color-black);
    text-decoration: none;
  }

  .nav-link {
    color: var(--color-black);
    text-decoration: none;
  }

  .nav-link.active {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .nav-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ===== Toolbar ===== */
  .toolbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.4rem 0.5rem;
    border-bottom: 1px solid #ccc;
    background: white;
    position: fixed;
    left: 0;
    right: 0;
    z-index: 99;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .toolbar input {
    flex: 1;
    padding: 0.3rem 0.5rem;
    border: 1px solid #ccc;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: white;
    outline: none;
  }

  .toolbar input:focus {
    border-color: #333;
  }

  .toolbar-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .result-count {
    font-size: 0.8rem;
    color: #999;
    white-space: nowrap;
  }

  /* ===== Confidence Legend ===== */
  .conf-legend {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.78rem;
    color: #555;
    white-space: nowrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: 1px solid #ccc;
    border-radius: 2px;
    padding: 0.15rem 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: #555;
    cursor: pointer;
    user-select: none;
    opacity: 0.35;
    transition: opacity 0.15s, border-color 0.15s;
  }

  .legend-item.active {
    opacity: 1;
    border-color: #bbb;
  }

  .legend-item:hover {
    border-color: #888;
    opacity: 1;
  }

  .legend-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .dot-high   { background: #c8e6c9; border: 1px solid #81c784; }
  .dot-medium { background: #fff9c4; border: 1px solid #f9cf5e; }
  .dot-low    { background: #ffcdd2; border: 1px solid #e57373; }
  .dot-none   { background: #e8e8e8; border: 1px solid #bbb; }

  /* ===== Loading ===== */
  .loading {
    text-align: center;
    padding: 4rem 0;
    font-family: var(--font-mono);
    color: var(--color-black);
  }

  .spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #ddd;
    border-top-color: var(--color-black);
    border-radius: 50%;
    margin: 0 auto 1rem;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ===== Table ===== */
  .table-wrapper {
    /* No overflow-x here — it breaks sticky thead positioning */
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.4;
    min-width: 1200px;
  }

  thead {
    z-index: 98;
  }

  th {
    position: sticky;
    z-index: 98;
    text-align: left;
    padding: 0.4rem 0.75rem;
    border: 1px solid #ccc;
    border-top: none;
    background: white;
    color: var(--color-accent);
    font-weight: 700;
    white-space: nowrap;
    text-decoration: underline dotted;
    text-underline-offset: 2px;
    cursor: pointer;
    user-select: none;
  }

  th.col-confidence {
    cursor: default;
    text-decoration: none;
  }

  th:hover {
    background: #f0f8f5;
  }

  th.col-confidence:hover {
    background: white;
  }

  .sort-icon {
    color: #aaa;
    font-size: 0.75rem;
  }

  td {
    padding: 0.5rem 0.75rem;
    border: 1px solid #ccc;
    background: white;
    vertical-align: top;
  }

  /* Source product — sticky left */
  .col-source-product {
    position: sticky;
    left: 0;
    z-index: 10;
    min-width: 220px;
    max-width: 300px;
    background: white;
    border-right: 2px solid #bbb;
  }

  thead .col-source-product {
    z-index: 111;
    background: white;
  }

  .col-matched-product {
    min-width: 220px;
    max-width: 300px;
  }

  .col-strength {
    min-width: 100px;
    max-width: 160px;
  }

  .col-confidence {
    min-width: 80px;
    max-width: 100px;
    white-space: nowrap;
  }

  .product-name {
    font-weight: 500;
  }

  .col-source-product .product-name,
  .col-matched-product .product-name {
    font-weight: 700;
  }

  .secondary-name {
    color: #555;
    font-weight: 700;
    padding-left: 0.25rem;
  }

