---
import events from "../content/2025.json";
const categories = [...new Set(events.map((e) => e.category))];
const getValenceColor = (valence: "Good" | "Bad") => {
  if (valence === "Good") return "green";
  if (valence === "Bad") return "#C7262C";
  if (valence === "?") return "#A6A09C";
};
---

<section class="entries">
  <div class="flex justify-end pointer-events-none w-full">
    <div
      class="flex flex-wrap justify-end gap-5 gap-y-4 w-fit bg-grey pointer-events-auto p-4 px-3 text-sm text-stone-500"
    >
      <div class="flex gap-2 items-center">
        SORT
        <select id="sort" class="truncate w-32 bg-white border-black p-1 rounded-md">
          <option value="prob">P(Generalises)</option>
          <option value="big">Big if True</option>
          <option value="ev">Expected Value (Big * P)</option>
        </select>
      </div>
      <div class="flex gap-2 items-center">
        CATEGORY
        <select id="filter" class="truncate w-32 bg-white border-black p-1 rounded-md">
          <option value="all">Everything</option>
          {categories.map((c) => <option value={c}>{c}</option>)}
        </select>
      </div>
    </div>
  </div>

  <div id="list-wrapper">
    {
      events &&
        events.length > 0 &&
        events
          .sort((a, b) => b["P(generalises)"] - a["P(generalises)"])
          .map((item, index) => (
            <div
              class="entry"
              data-index={index}
              data-category={item.category}
              data-valence={item.valence}
              data-evidence={item.evidence}
              data-prob={item["P(generalises)"]}
              data-big={item["big | true"]}
              data-ev={item["big & true"]}
            >
              <div class="probs">
                <div
                  class="probs-true"
                  title={"P(generalises) = " + item["P(generalises)"]}
                  style={{
                    width: `${item["P(generalises)"] * 100}%`,
                    border: "solid 1px " + getValenceColor(item.valence),
                    "border-right": "none",
                    "--stripe-color": getValenceColor(item.valence),
                  }}
                />
              </div>

              <div class="content">
                <h3>{item.summary}</h3>
                <details>
                  <summary>+</summary>
                  <div class="text-sm pt-1 text-stone-500">
                    {item.commentary && <div class="pb-3">{item.commentary}</div>}
                    <div class="flex gap-x-5 gap-y-0 flex-wrap">
                      <div>
                        P(true) = <span class="text-black">{item["P(generalises)"]}</span>
                      </div>
                      <div>
                        Big | True = <span class="text-black">{item["big | true"]}</span>
                      </div>
                      <div>
                        Big * P(true) = <span class="text-black">{item["big & true"]}</span>
                      </div>
                    </div>
                  </div>
                </details>
              </div>

              <div class="categories">
                <div>{item.category}</div>
                <div>{item.subcategory}</div>
                <div>{item.subsub}</div>
              </div>

              <div class="links">
                {item.evidence && (
                  <div>
                    {item.evidence == "Speculation"
                      ? "❓ "
                      : item.evidence == "Established fact"
                        ? "❗️ "
                        : item.evidence == "Demo"
                          ? "🛠️ "
                          : item.evidence == "RCT"
                            ? "🧪 "
                            : item.evidence == "Real-world evidence"
                              ? "📈 "
                              : ""}
                    {item.evidence}
                  </div>
                )}
                {item.primary_source && (
                  <a href={item.primary_source} class="pill">
                    ○ Primary source
                  </a>
                )}
                {item.other_sources && (
                  <a href={item.other_sources} class="pill">
                    ○ Secondary source
                  </a>
                )}
              </div>
            </div>
          ))
    }
  </div>
</section>

<script>
  const filterSelect = document.getElementById("filter");
  const sortSelect = document.getElementById("sort");
  const listWrapper = document.getElementById("list-wrapper");

  const originalItems = Array.from(listWrapper.children) as HTMLElement[];

  function updateList() {
    const sortValue = sortSelect.value;
    const filterValue = filterSelect.value;

    // 1. Create a copy of the array to sort
    let items = [...originalItems];

    if (sortValue !== "default") {
      items.sort((a, b) => {
        let valA = 0,
          valB = 0;

        if (sortValue === "prob") {
          valA = parseFloat(a.dataset.prob || "0");
          valB = parseFloat(b.dataset.prob || "0");
        } else if (sortValue === "big") {
          valA = parseFloat(a.dataset.big || "0");
          valB = parseFloat(b.dataset.big || "0");
        } else if (sortValue === "ev") {
          valA = parseFloat(a.dataset.ev || "0");
          valB = parseFloat(b.dataset.ev || "0");
        }
        return valB - valA;
      });
    } else {
      items.sort((a, b) => {
        return parseInt(a.dataset.index || "0") - parseInt(b.dataset.index || "0");
      });
    }

    listWrapper.innerHTML = "";

    items.forEach((item) => {
      const category = item.dataset.category;

      if (filterValue === "all" || category === filterValue) {
        item.style.display = "flex"; // Ensure it's visible
        listWrapper.appendChild(item);
      } else {
        item.style.display = "none";
        listWrapper.appendChild(item);
      }
    });
  }

  // Add listeners
  sortSelect.addEventListener("change", updateList);
  filterSelect.addEventListener("change", updateList);
</script>

<style>
  .entries {
    margin-left: calc(20rem + 100px);
    padding-bottom: 2rem;
    width: calc(100% - 20rem - 100px);
  }

  .entry {
    background: white;
    border-bottom: solid 0.5px #ccc;
    border-left: solid 0.5px #ccc;
    padding: 1.2rem 1.5rem;
    display: flex;
    gap: 48px;
    position: relative;
    min-height: 8rem;
  }

  .entry .content {
    width: 65%;
    flex-grow: 0;
  }

  .categories {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 12px;
    width: 10rem;
    flex-shrink: 0;
    /*font-family: monospace;*/
    font-size: 0.9em;
    /*text-transform: uppercase;*/
  }

  .links {
    width: 10rem;
    flex-shrink: 0;
    display: grid;
    gap: 12px;
    height: fit-content;
    font-size: 0.9em;
  }

  .pill {
    color: var(--color-theme);
  }

  .probs {
    position: absolute;
    left: -100.5px;
    top: 22px;
    width: 100px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .probs-true {
    height: 16px;
    background-image: linear-gradient(
      45deg,
      var(--stripe-color) 25%,
      transparent 25%,
      transparent 50%,
      var(--stripe-color) 50%,
      var(--stripe-color) 75%,
      transparent 75%,
      transparent
    );
    background-size: 4px 4px;
  }

  .entry h3 {
    font-size: 1.2rem;
    margin-bottom: 0px;
  }

  @media (max-width: 1024px) {
    .entries {
      padding-left: 100px;
      margin-left: 0px;
      width: 100%;
      margin-top: 1em;
    }
  }

  @media (max-width: 650px) {
    .entries {
      margin-left: 0px;
      width: 100%;
      padding-left: 50px;
    }

    .entry {
      border-left: none;
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .entry .content {
      width: 100%;
    }

    .categories {
      width: 100%;
      flex-direction: row;
      gap: 0.5rem 1rem;
      flex-wrap: wrap;
    }

    .links {
      width: 100%;
    }

    .probs {
      width: 50px;
      left: -50.5px;
    }
  }
</style>
