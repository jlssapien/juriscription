---
import events from "../content/2025.json";
const categories = [...new Set(events.map((e) => e.category))];
const getValenceColor = (valence: "Good" | "Bad") => {
  if (valence === "Good") return "green";
  if (valence === "Bad") return "#C7262C";
};
---

<section class="entries">
  <div class="flex justify-end pointer-events-none w-full">
    <div class="flex gap-6 w-fit bg-grey pointer-events-auto p-4 text-sm text-stone-500">
      <div class="flex gap-2 items-center">
        SORT
        <select id="sort" class="truncate w-24 bg-white border-black p-1 rounded-md">
          <option> Default </option>
          <option> P(true) </option>
          <option> big | true </option>
          <option> big & true </option>
        </select>
      </div>
      <div class="flex gap-2 items-center">
        FILTER
        <select id="filter" class="truncate w-24 bg-white border-black p-1 rounded-md">
          <option value="all">No filter</option>
          <option disabled> Category </option>
          {categories.map((c) => <option value={c}>{c}</option>)}
          <hr />
          <option disabled> Valence </option>
          <option> Good </option>
          <option> Bad </option>
          <hr />
          <option disabled> Evidence type </option>
          <option> Demo </option>
          <option> RCT </option>
          <option> Real-world evidence </option>
          <option> Speculation </option>
          <option> Established fact </option>
        </select>
      </div>
    </div>
  </div>

  <div class="list-wrapper">
    {
      events &&
        events.length > 0 &&
        events.map((item) => (
          <div
            class="entry"
            data-category={item.category}
            data-valence={item.valence}
            data-evidence={item.evidence}
            data-prob={item["P(generalises)"]}
            data-scale={item["big | true"]}
          >
            <div class="probs">
              <div
                class="probs-true"
                style={{
                  width: `${item["P(generalises)"] * 100}%`,
                  border: "solid 1px " + getValenceColor(item.valence),
                  "border-right": "none",
                  "--stripe-color": getValenceColor(item.valence),
                }}
              />
            </div>

            <div class="content">
              <h3>{item.summary}</h3>
              <details>
                <summary>+</summary>
                <div class="text-sm pt-1 text-stone-500">
                  {item.commentary && <div class="pb-3">{item.commentary}</div>}
                  <div class="flex gap-x-5 gap-y-0 flex-wrap">
                    <div>
                      P(true) = <span class="text-black">{item["P(generalises)"]}</span>
                    </div>
                    <div>
                      Big | True = <span class="text-black">{item["big | true"]}</span>
                    </div>
                    <div>
                      Big * P(true) = <span class="text-black">{item["big & true"]}</span>
                    </div>
                  </div>
                </div>
              </details>
            </div>

            <div class="categories">
              <div>{item.category}</div>
              <div>{item.subcategory}</div>
              <div>{item.subsub}</div>
            </div>

            <div class="links">
              {item.evidence && (
                <div>
                  {item.evidence == "Speculation"
                    ? "❓ "
                    : item.evidence == "Established fact"
                      ? "❗️ "
                      : item.evidence == "Demo"
                        ? "🛠️ "
                        : item.evidence == "RCT"
                          ? "🧪 "
                          : item.evidence == "Real-world evidence"
                            ? "📈 "
                            : ""}
                  {item.evidence}
                </div>
              )}
              {item.primary_source && (
                <a href={item.primary_source} class="pill">
                  ○ Primary source
                </a>
              )}
              {item.other_sources && (
                <a href={item.other_sources} class="pill">
                  ○ Secondary source
                </a>
              )}
            </div>
          </div>
        ))
    }
  </div>
</section>

<script>
  const filterSelect = document.getElementById("filter");
  const sortSelect = document.getElementById("sort");
  const listWrapper = document.getElementById("list-wrapper");
  // Store original order for reset
  const originalOrder = Array.from(listWrapper.children);

  filterSelect.addEventListener("change", (e) => {
    const category = e.target.value;
    const entries = document.querySelectorAll(".entry");

    entries.forEach((entry) => {
      if (category === "all" || entry.dataset.category === category) {
        entry.style.display = "flex"; // or whatever your display is
      } else {
        entry.style.display = "none";
      }
    });
  });

  // 2. Handle Sorting (The annoying part in Vanilla JS)
  sortSelect.addEventListener("change", (e) => {
    const method = e.target.value;
    const entries = Array.from(listWrapper.children);

    let sortedEntries;

    if (method === "default") {
      sortedEntries = originalOrder; // Reset to DOM order
    } else if (method === "prob_desc") {
      sortedEntries = entries.sort((a, b) => {
        return parseFloat(b.dataset.prob) - parseFloat(a.dataset.prob);
      });
    }

    // Detach and re-append in new order
    listWrapper.innerHTML = "";
    sortedEntries.forEach((node) => listWrapper.appendChild(node));
  });
</script>

<style>
  .entries {
    margin-left: calc(20rem + 100px);
    padding-bottom: 2rem;
    width: calc(100% - 20rem - 100px);
  }

  .entry {
    background: white;
    border-bottom: solid 0.5px #ccc;
    border-left: solid 0.5px #ccc;
    padding: 1.2rem 1.5rem;
    display: flex;
    gap: 48px;
    position: relative;
    min-height: 8rem;
  }

  .entry .content {
    width: 65%;
    flex-grow: 0;
  }

  .categories {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 12px;
    width: 10rem;
    flex-shrink: 0;
    /*font-family: monospace;*/
    font-size: 0.9em;
    /*text-transform: uppercase;*/
  }

  .links {
    width: 10rem;
    flex-shrink: 0;
    display: grid;
    gap: 12px;
    height: fit-content;
    font-size: 0.9em;
  }

  .pill {
    color: var(--color-theme);
  }

  .probs {
    position: absolute;
    left: -100.5px;
    top: 22px;
    width: 100px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .probs-true {
    height: 16px;
    background-image: linear-gradient(
      45deg,
      var(--stripe-color) 25%,
      transparent 25%,
      transparent 50%,
      var(--stripe-color) 50%,
      var(--stripe-color) 75%,
      transparent 75%,
      transparent
    );
    background-size: 4px 4px;
  }

  .entry h3 {
    font-size: 1.2rem;
    margin-bottom: 0px;
  }

  @media (max-width: 1024px) {
    .entries {
      padding-left: 100px;
      margin-left: 0px;
      width: 100%;
      margin-top: 1em;
    }
  }

  @media (max-width: 650px) {
    .entries {
      margin-left: 0px;
      width: 100%;
      padding-left: 50px;
    }

    .entry {
      border-left: none;
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .entry .content {
      width: 100%;
    }

    .categories {
      width: 100%;
      flex-direction: row;
      gap: 0.5rem 1rem;
      flex-wrap: wrap;
    }

    .links {
      width: 100%;
    }

    .probs {
      width: 50px;
      left: -50.5px;
    }
  }
</style>
